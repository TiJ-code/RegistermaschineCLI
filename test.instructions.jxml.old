<?xml version="1.0" encoding="utf-8" ?>
<!DOCTYPE instruction-set SYSTEM "dtd/instruction_file.dtd">
<instruction-set>
    <name>Registermaschine Instruction Set</name>
    <options>
        <option id="allowLabels" value="false"/>
    </options>
    <instructions>
        <instruction
                id="hlt"
                opcode="0x00"
                description="End instruction to stop execution"
                handler="dk.tij.registermaschine.instructions.HaltInstruction">
            <operand type="immediate" concept="operand"/>
        </instruction>
        <instruction
                id="add"
                opcode="0x01"
                description="Adds register B to A"
                handler="dk.tij.registermaschine.instructions.AdditionInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="register" concept="operand" implicitValue="r0"/>
            <operand type="register" concept="operand"/>
        </instruction>
        <instruction
                id="sub"
                opcode="0x02"
                description="Subtracts register B from A"
                handler="dk.tij.registermaschine.instructions.SubtractionInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="register" concept="operand" implicitValue="r0"/>
            <operand type="register" concept="operand"/>
        </instruction>
        <instruction
                id="mul"
                opcode="0x03"
                description="Multiplies register A by B"
                handler="dk.tij.registermaschine.instructions.MultiplicationInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="register" concept="operand" implicitValue="r0"/>
            <operand type="register" concept="operand"/>
        </instruction>
        <instruction
                id="div"
                opcode="0x04"
                description="Divides register A by B"
                handler="dk.tij.registermaschine.instructions.DivisionInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="register" concept="operand" implicitValue="r0"/>
            <operand type="register" concept="operand"/>
        </instruction>
        <instruction
                id="lda"
                opcode="0x06"
                description="Loads value from register A into accumulator"
                handler="dk.tij.registermaschine.instructions.MoveInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="register" concept="operand"/>
        </instruction>
        <instruction
                id="ldk"
                opcode="0x07"
                description="Loads constant value into accumulator"
                handler="dk.tij.registermaschine.instructions.MoveInstruction">
            <operand type="register" concept="result" implicitValue="r0"/>
            <operand type="immediate" concept="operand"/>
        </instruction>
        <instruction
                id="sta"
                opcode="0x08"
                description="Stores value of accumulator into register A"
                handler="dk.tij.registermaschine.instructions.MoveInstruction">
            <operand type="register" concept="operand" implicitValue="r0"/>
            <operand type="register" concept="result"/>
        </instruction>
        <instruction
                id="inp"
                opcode="0x09"
                description="Awaits input to store in register A"
                handler="dk.tij.registermaschine.instructions.InputInstruction">
            <operand type="register" concept="result"/>
        </instruction>
        <instruction
                id="out"
                opcode="0x0A"
                description="Outputs content from accumulator onto display"
                handler="dk.tij.registermaschine.instructions.OutputInstruction">
            <operand type="register" concept="operand" implicitValue="r0"/>
        </instruction>
        <instruction
                id="jmp"
                opcode="0x0B"
                description="Jumps to program line"
                handler="dk.tij.registermaschine.instructions.JumpInstruction">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jez"
                opcode="0x0C"
                description="Jumps to program line, if accumulator is zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="core.conditions.EqualsZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jne"
                opcode="0x0D"
                description="Jumps to program line, if accumulator is not zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="@core.conditions.NotEqualsZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jlz"
                opcode="0x0E"
                description="Jumps to program line, if accumulator is less than zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="core.conditions.LessThanZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jle"
                opcode="0x0F"
                description="Jumps to program line, if accumulator is less than or equal to zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="@core.conditions.LessThanOrEqualsToZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jgz"
                opcode="0x10"
                description="Jumps to program line, if accumulator is greater than zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="@core.conditions.GreaterThanZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
        <instruction
                id="jge"
                opcode="0x11"
                description="Jumps to program line, if accumulator is greater than or equal to zero"
                handler="dk.tij.registermaschine.instructions.JumpInstruction"
                condition="@core.conditions.GreaterThanOrEqualsToZeroCondition">
            <operand type="label" concept="target"/>
        </instruction>
    </instructions>
</instruction-set>